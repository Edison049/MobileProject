<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#141414"
    android:gravity="center">

    <!-- Logo区域 -->
    <ImageView
        android:id="@+id/logo_image"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_marginBottom="32dp"
        android:src="@drawable/ic_launcher_foreground"
        android:contentDescription="应用Logo" />

    <!-- 标题 -->
    <TextView
        android:id="@+id/title_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="电影租赁系统"
        android:textSize="28sp"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/subtitle_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="登录您的账户"
        android:textSize="16sp"
        android:textColor="#B3B3B3"
        android:layout_marginBottom="32dp" />

    <!-- 邮箱输入框 -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/email_input_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:textColorHint="#B3B3B3"
        app:boxStrokeColor="#E50914"
        app:hintTextColor="#E50914">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/email_edit_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="邮箱地址"
            android:inputType="textEmailAddress"
            android:textColor="#FFFFFF"
            android:textColorHint="#B3B3B3" />

    </com.google.android.material.textfield.TextInputLayout>

    <!-- 密码输入框 -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/password_input_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:textColorHint="#B3B3B3"
        app:boxStrokeColor="#E50914"
        app:hintTextColor="#E50914"
        app:endIconMode="password_toggle"
        app:endIconTint="#B3B3B3">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/password_edit_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="密码"
            android:inputType="textPassword"
            android:textColor="#FFFFFF"
            android:textColorHint="#B3B3B3" />

    </com.google.android.material.textfield.TextInputLayout>

    <!-- 登录按钮 -->
    <Button
        android:id="@+id/login_button"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="登录"
        android:textSize="16sp"
        android:textStyle="bold"
        android:backgroundTint="#E50914"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="16dp"
        android:elevation="4dp" />

    <!-- 注册链接 -->
    <TextView
        android:id="@+id/register_link"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="还没有账户？立即注册"
        android:textColor="#E50914"
        android:textSize="14sp"
        android:padding="8dp"
        android:clickable="true"
        android:focusable="true" />

    <!-- 测试账户提示 -->
    <TextView
        android:id="@+id/test_account_hint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="测试账户:\nMary: mary@example.com / mary123\nJohn: john@example.com / john123"
        android:textColor="#B3B3B3"
        android:textSize="12sp"
        android:gravity="center"
        android:lineSpacingExtra="4dp" />

</LinearLayout>