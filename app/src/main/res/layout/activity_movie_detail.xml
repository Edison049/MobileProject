<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#141414">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 电影海报区域 -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="300dp">

                <ImageView
                    android:id="@+id/movie_poster_large"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_launcher_foreground"
                    android:contentDescription="电影海报" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/gradient_overlay" />

                <!-- 返回按钮 -->
                <ImageButton
                    android:id="@+id/back_button"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_margin="16dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@android:drawable/ic_menu_revert"
                    app:tint="#FFFFFF"
                    android:contentDescription="返回" />

            </FrameLayout>

            <!-- 电影基本信息 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/movie_title_detail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="电影标题"
                    android:textSize="28sp"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:id="@+id/movie_rating_detail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="8.5★"
                        android:textSize="16sp"
                        android:textColor="#FFD700"
                        android:layout_marginEnd="16dp" />

                    <TextView
                        android:id="@+id/movie_genre_detail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="动作片"
                        android:textSize="14sp"
                        android:textColor="#B3B3B3"
                        android:background="#333333"
                        android:padding="4dp"
                        android:layout_marginEnd="16dp" />

                    <TextView
                        android:id="@+id/movie_duration_detail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="120分钟"
                        android:textSize="14sp"
                        android:textColor="#B3B3B3" />

                </LinearLayout>

                <TextView
                    android:id="@+id/movie_price_detail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="价格: 150积分"
                    android:textSize="18sp"
                    android:textColor="#E50914"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp" />

            </LinearLayout>

            <!-- 视频预览区域 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="#1f1f1f"
                android:layout_marginBottom="16dp">
            
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="预告片"
                    android:textSize="18sp"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />
            
                <!-- 视频预览播放器 -->
                <include
                    layout="@layout/simple_video_player"
                    android:id="@+id/video_preview_player"
                    android:layout_width="match_parent"
                    android:layout_height="300dp" />
            
            </LinearLayout>

            <!-- 电影详情信息 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="导演"
                    android:textSize="16sp"
                    android:textColor="#B3B3B3"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/movie_director_detail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="导演姓名"
                    android:textSize="16sp"
                    android:textColor="#FFFFFF"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="主演"
                    android:textSize="16sp"
                    android:textColor="#B3B3B3"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/movie_cast_detail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="演员列表"
                    android:textSize="16sp"
                    android:textColor="#FFFFFF"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="剧情简介"
                    android:textSize="16sp"
                    android:textColor="#B3B3B3"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/movie_description_detail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="这里是电影的详细剧情介绍..."
                    android:textSize="14sp"
                    android:textColor="#CCCCCC"
                    android:lineSpacingExtra="4dp" />

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- 底部操作按钮 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="horizontal"
        android:padding="16dp"
        android:background="#000000"
        android:elevation="8dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/add_to_cart_button"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:text="加入购物车"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginEnd="8dp"
            app:backgroundTint="#E50914" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buy_now_button"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:text="立即购买"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginStart="8dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            app:strokeColor="#E50914"
            app:strokeWidth="2dp"
            android:textColor="#E50914" />

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>